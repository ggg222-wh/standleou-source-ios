bool is_dyld_hidden(const std::string& name)
{
    for (const auto& path : dyld_hidden)
    {
        if (name.find(path) != std::string::npos)
            return true;
    }

    return false;
}

struct dyld_idx_t {
    int idx;
    std::unique_ptr<char[]> name;
    const mach_header* header;
    intptr_t slide;
};

std::vector<dyld_idx_t> dyld_summary;

void aggregate_dyld() {
    dyld_summary.clear();
    int count = _dyld_image_count();

    for (int i = 0; i < count; i++) {
        const char* name = _dyld_get_image_name(i);
        if (!name) continue;

        std::string s(name);
        if (is_dyld_hidden(s)) {
            continue;
        }

        char* stable = strdup(name);
        dyld_summary.push_back({ i, std::unique_ptr<char[]>(stable), _dyld_get_image_header(i), _dyld_get_image_vmaddr_slide(i) });
    }
}

%group dyld_hooks

%hookf(uint32_t, _dyld_image_count)
{
    return static_cast<uint32_t>(dyld_summary.size());   
}

%hookf(const char*, _dyld_get_image_name, uint32_t index) 
{
    if (index >= dyld_summary.size()) {
        return nullptr;
    }

    return dyld_summary[index].name.get();
}

%hookf(const struct mach_header*, _dyld_get_image_header, uint32_t index) 
{
    if (index < 0 || index >= static_cast<int>(dyld_summary.size()))
        return nullptr;
    return dyld_summary[index].header;
}

%hookf(intptr_t, _dyld_get_image_vmaddr_slide, uint32_t index)
{
    if (index < 0 || index >= static_cast<int>(dyld_summary.size()))
        return 0;
    return dyld_summary[index].slide;
}

%end

std::array<std::string, 6> hidden =
{
