    crypt_string("antisocial.dylib"),
    crypt_string("libsubstrate.dylib"),
    crypt_string("substrate"),
    crypt_string("jbroot"),
    crypt_string("TweakInject")
};

bool is_lib_hidden(const std::string& lib)
{
    return std::find(hidden.begin(), hidden.end(), lib) != hidden.end();
}

kern_return_t (*og_task_info)(task_name_t target_task, task_flavor_t flavor, task_info_t task_info_out, mach_msg_type_number_t* task_info_outCnt);
kern_return_t hk_task_info(task_name_t target_task, task_flavor_t flavor, task_info_t task_info_out, mach_msg_type_number_t* task_info_outCnt) {
    if (flavor == TASK_DYLD_INFO)
    {
        kern_return_t kret = og_task_info(target_task, flavor, task_info_out, task_info_outCnt);

        if(kret == KERN_SUCCESS)
        {
            struct task_dyld_info* task_inf = (struct task_dyld_info*)task_info_out;
            struct dyld_all_image_infos* dyld_info = (struct dyld_all_image_infos*)task_inf->all_image_info_addr;
            size_t dyld_info_count = dyld_info->infoArrayCount;
            struct dyld_image_info* new_info_array = (struct dyld_image_info*)malloc(sizeof(struct dyld_image_info) * dyld_info_count);
            size_t new_info_count = 0;

            for(int i = 0; i < dyld_info_count; i++)
            {
                auto info = dyld_info->infoArray[i];
                if(is_lib_hidden(info.imageFilePath)) {
                    continue;
                }

                new_info_array[new_info_count++] = info;
            }
            
            dyld_info->infoArray = new_info_array;
            dyld_info->infoArrayCount = (uint32_t)new_info_count;
        }
        return kret;
    }

    return og_task_info(target_task, flavor, task_info_out, task_info_outCnt);
}

%hookf(kern_return_t, task_info, task_name_t target_task, task_flavor_t flavor, task_info_t task_info_out, mach_msg_type_number_t* task_info_outCnt)
{
    if(flavor == TASK_DYLD_INFO)
    {
        kern_return_t kret = %orig(target_task, flavor, task_info_out, task_info_outCnt);

        if(kret == KERN_SUCCESS)
        {
            struct task_dyld_info* task_inf = (struct task_dyld_info*)task_info_out;
            struct dyld_all_image_infos* dyld_info = (struct dyld_all_image_infos*)task_inf->all_image_info_addr;
            size_t dyld_info_count = dyld_info->infoArrayCount;
            struct dyld_image_info* new_info_array = (struct dyld_image_info*)malloc(sizeof(struct dyld_image_info) * dyld_info_count);
            size_t new_info_count = 0;

            for(int i = 0; i < dyld_info_count; i++)
            {
                auto info = dyld_info->infoArray[i];
                if(is_lib_hidden(info.imageFilePath)) {
                    continue;
                }

                new_info_array[new_info_count++] = info;
            }
            
            dyld_info->infoArray = new_info_array;
            dyld_info->infoArrayCount = (uint32_t)new_info_count;
        }
        return kret;
    }

    return %orig(target_task, flavor, task_info_out, task_info_outCnt);
}

%hook NSURLSession
- (NSURLSessionDataTask *)dataTaskWithRequest:(NSURLRequest *)request
                          completionHandler:(void (^)(NSData *, NSURLResponse *, NSError *))completionHandler
{
    id url = ((id(*)(id, SEL))objc_msgSend)(request, sel_registerName(ay_obfuscate("URL")));
    id urlString = ((id(*)(id, SEL))objc_msgSend)(url, sel_registerName(ay_obfuscate("absoluteString")));

    SEL containsSel = sel_registerName(ay_obfuscate("containsString:"));
    id fantaStr = ns_encrypt("fanta");
    id iosStr = ns_encrypt("ios");
    id timeStr = ns_encrypt("time");
    BOOL containsFanta = ((BOOL(*)(id, SEL, id))objc_msgSend)(urlString, containsSel, fantaStr)
                         && (((BOOL(*)(id, SEL, id))objc_msgSend)(urlString, containsSel, iosStr));

    if (containsFanta) {
        void (^fakeCompletion)(NSData *, NSURLResponse *, NSError *) = ^(NSData *data, NSURLResponse *response, NSError *error) {
            if (completionHandler) {
                id contentTypeKey = ns_encrypt("Content-Type");
                id contentTypeValue = ns_encrypt("text/plain");
                id headerDict = [NSDictionary dictionaryWithObject:contentTypeValue forKey:contentTypeKey];

                Class NSHTTPURLResponseClass = objc_getClass(ay_obfuscate("NSHTTPURLResponse"));
                SEL allocSel = sel_registerName(ay_obfuscate("alloc"));
                SEL initSel = sel_registerName(ay_obfuscate("initWithURL:statusCode:HTTPVersion:headerFields:"));
                id fakeResponse = ((id(*)(id, SEL, id, NSInteger, id, id))objc_msgSend)(
                    ((id(*)(id, SEL))objc_msgSend)(NSHTTPURLResponseClass, allocSel),
                    initSel,
                    request.URL,
                    200,
                    ns_encrypt("HTTP/1.1"),
                    headerDict
                );
                completionHandler([ns_encrypt("DEEPSEEK 30$ ANTICHEAT PWNED BY @antisocial_pub! SOSI ZHIRNIY PIDORAS =) -> $$$ GANG <-") dataUsingEncoding:NSUTF8StringEncoding], fakeResponse, nil);
            }
        };

        NSURLSessionDataTask *task = %orig(request, fakeCompletion);
        dispatch_async(dispatch_get_main_queue(), ^{
            fakeCompletion(nil, nil, nil);
        });
        return task;
    }

    return %orig(request, completionHandler);
}
%end

%hook NSURLConnection
+ (NSData *)sendSynchronousRequest:(NSURLRequest *)request
                returningResponse:(NSURLResponse **)response
                            error:(NSError **)error
{
    
    id url = ((id(*)(id, SEL))objc_msgSend)(request, sel_registerName(ay_obfuscate("URL")));
    id urlString = ((id(*)(id, SEL))objc_msgSend)(url, sel_registerName(ay_obfuscate("absoluteString")));

    SEL containsSel = sel_registerName(ay_obfuscate("containsString:"));
    id fantaStr = ns_encrypt("fanta");
    id iosStr = ns_encrypt("ios");
    id timeStr = ns_encrypt("time");
    BOOL containsFanta = ((BOOL(*)(id, SEL, id))objc_msgSend)(urlString, containsSel, fantaStr)
                         && (((BOOL(*)(id, SEL, id))objc_msgSend)(urlString, containsSel, iosStr));

    if (containsFanta) {
        if (response) {
            id contentTypeKey = ns_encrypt("Content-Type");
            id contentTypeValue = ns_encrypt("text/plain");
            id headerDict = [NSDictionary dictionaryWithObject:contentTypeValue forKey:contentTypeKey];

            Class NSHTTPURLResponseClass = objc_getClass(ay_obfuscate("NSHTTPURLResponse"));
            SEL allocSel = sel_registerName(ay_obfuscate("alloc"));
            SEL initSel = sel_registerName(ay_obfuscate("initWithURL:statusCode:HTTPVersion:headerFields:"));
            id fakeResponse = ((id(*)(id, SEL, id, NSInteger, id, id))objc_msgSend)(
                ((id(*)(id, SEL))objc_msgSend)(NSHTTPURLResponseClass, allocSel),
                initSel,
                request.URL,
                200,
                ns_encrypt("HTTP/1.1"),
                headerDict
            );
            *response = fakeResponse;
        }
        if (error) *error = nil;

        return [ns_encrypt("DEEPSEEK 30$ ANTICHEAT PWNED BY @antisocial_pub! SOSI ZHIRNIY PIDORAS =) -> $$$ GANG <-") dataUsingEncoding:NSUTF8StringEncoding];
    }

    return %orig(request, response, error);
}
%end

static inline bool is_hidden_path(const char * path) {
    if (!path) return false;
    std::string s(path);
    for (auto &h: hidden) {
        if (s.find(h) != std::string::npos && s.find(crypt_string(".png")) == std::string::npos) {
            return true;
        }
    }
    return false;
}

static inline bool is_hidden_nsstring(NSString *str) {
    if (!str) return false;

    id lower = ((id(*)(id,SEL))objc_msgSend)(str, sel_registerName(ay_obfuscate("lowercaseString")));

    for (auto &h : hidden) {
        id h_ns = ((id(*)(Class,SEL,const char*))objc_msgSend)(
            objc_getClass(ay_obfuscate("NSString")),
            sel_registerName(ay_obfuscate("stringWithUTF8String:")),
            h.c_str()
        );

        id pngStr = ((id(*)(Class,SEL,const char*))objc_msgSend)(
            objc_getClass(ay_obfuscate("NSString")),
            sel_registerName(ay_obfuscate("stringWithUTF8String:")),
            ay_obfuscate(".png")
        );

        SEL selContains = sel_registerName(ay_obfuscate("containsString:"));
        bool contains_h = ((bool(*)(id,SEL,id))objc_msgSend)(lower, selContains, h_ns);
        bool contains_png = ((bool(*)(id,SEL,id))objc_msgSend)(lower, selContains, pngStr);

        if (contains_h && !contains_png) {
            return true;
        }
    }
    return false;
}

%hook NSBundle
+ (NSArray<NSBundle *> *)allFrameworks {
    id arr = %orig;
    id mutableArr = ((id(*)(id,SEL))objc_msgSend)(arr, sel_registerName(ay_obfuscate("mutableCopy")));
    id copyArr = ((id(*)(id,SEL))objc_msgSend)(mutableArr, sel_registerName(ay_obfuscate("copy")));

    SEL selBundlePath = sel_registerName(ay_obfuscate("bundlePath"));
    SEL selRemove = sel_registerName(ay_obfuscate("removeObject:"));
    SEL selCount = sel_registerName(ay_obfuscate("count"));
    SEL selObjectAtIndex = sel_registerName(ay_obfuscate("objectAtIndex:"));

    NSInteger count = ((NSInteger(*)(id,SEL))objc_msgSend)(copyArr, selCount);
    for(NSInteger i = count - 1; i >= 0; i--) {
        id b = ((id(*)(id,SEL,NSInteger))objc_msgSend)(copyArr, selObjectAtIndex, i);
        id path = ((id(*)(id,SEL))objc_msgSend)(b, selBundlePath);
        if(is_hidden_nsstring(path)) {
            ((void(*)(id,SEL,id))objc_msgSend)(mutableArr, selRemove, b);
        }
    }
    return mutableArr;
}

+ (NSArray<NSBundle *> *)allBundles {
    id arr = %orig;
    id mutableArr = ((id(*)(id,SEL))objc_msgSend)(arr, sel_registerName(ay_obfuscate("mutableCopy")));
    id copyArr = ((id(*)(id,SEL))objc_msgSend)(mutableArr, sel_registerName(ay_obfuscate("copy")));

    SEL selBundlePath = sel_registerName(ay_obfuscate("bundlePath"));
    SEL selRemove = sel_registerName(ay_obfuscate("removeObject:"));
    SEL selCount = sel_registerName(ay_obfuscate("count"));
    SEL selObjectAtIndex = sel_registerName(ay_obfuscate("objectAtIndex:"));

    NSInteger count = ((NSInteger(*)(id,SEL))objc_msgSend)(copyArr, selCount);
    for(NSInteger i = count - 1; i >= 0; i--) {
        id b = ((id(*)(id,SEL,NSInteger))objc_msgSend)(copyArr, selObjectAtIndex, i);
        id path = ((id(*)(id,SEL))objc_msgSend)(b, selBundlePath);
        if(is_hidden_nsstring(path)) {
            ((void(*)(id,SEL,id))objc_msgSend)(mutableArr, selRemove, b);
        }
    }
    return mutableArr;
}
%end

%hook NSObject
+ (int)objc_getClassList:(Class *)buffer bufferCount:(int)count {
    int ret = %orig(buffer,count);
    int newCount = 0;

    for(int i=0;i<ret;i++) {
        const char* clsName = class_getName(buffer[i]);
        if(!is_hidden_path(clsName)) {
            buffer[newCount++] = buffer[i];
        }
    }
    return newCount;
}
%end

%hookf(int, stat, const char *path, struct stat *buf) {
    if (is_hidden_path(path)) {
        errno = ENOENT;
        return -1;
    }
    return %orig(path, buf);
}

%hookf(int, access, const char *path, int mode) {
    if (is_hidden_path(path)) {
        errno = ENOENT;
        return -1;
    }
    return %orig(path, mode);
}

%hookf(struct dirent *, readdir, DIR *dirp) {
    struct dirent *ent;
    while ((ent = %orig(dirp))) {
        if (is_hidden_path(ent->d_name)) continue;
        return ent;
    }
    return NULL;
}

%hookf(int, dladdr, const void *addr, Dl_info *info) {
    int ret = %orig(addr, info);
    if (ret != 0 && info && info->dli_fname && is_hidden_path(info->dli_fname)) {
        info->dli_fname = "";
    }
    return ret;
}

%hookf(void*, dlopen, const char *path, int mode) {
    if (is_hidden_path(path)) {
        errno = ENOENT;
        return NULL;
    }
    return %orig(path, mode);
}

%hook NSFileManager
- (NSArray<NSString *> *)contentsOfDirectoryAtPath:(NSString *)path error:(NSError **)error {
    NSArray *orig = %orig(path,error);
    if(!orig) return nil;

    id filtered = ((id(*)(id,SEL))objc_msgSend)(orig, sel_registerName(ay_obfuscate("mutableCopy")));
    SEL selCount = sel_registerName(ay_obfuscate("count"));
    SEL selObjectAtIndex = sel_registerName(ay_obfuscate("objectAtIndex:"));
    SEL selRemove = sel_registerName(ay_obfuscate("removeObject:"));

    NSInteger count = ((NSInteger(*)(id,SEL))objc_msgSend)(orig, selCount);
    for(NSInteger i = count - 1; i >= 0; i--) {
        id f = ((id(*)(id,SEL,NSInteger))objc_msgSend)(orig, selObjectAtIndex, i);
        if(is_hidden_nsstring(f)) {
            ((void(*)(id,SEL,id))objc_msgSend)(filtered, selRemove, f);
        }
    }

    return filtered;
}
%end

%hook UIViewController
- (void)presentViewController:(id)viewController animated:(BOOL)flag completion:(id)completion {
    Class UIAlertCls = objc_getClass(ay_obfuscate("UIAlertController"));
    if ([viewController isKindOfClass:UIAlertCls]) {
        id title = ((id(*)(id,SEL))objc_msgSend)(viewController, sel_registerName(ay_obfuscate("title")));
        id message = ((id(*)(id,SEL))objc_msgSend)(viewController, sel_registerName(ay_obfuscate("message")));

        SEL selRange = sel_registerName(ay_obfuscate("rangeOfString:options:"));
        bool hasError = false;
        bool hasTechnical = false;

        if(title) {
            NSRange r = ((NSRange(*)(id,SEL,id,NSUInteger))objc_msgSend)(title, selRange, ns_encrypt("error"), 1 /*NSCaseInsensitiveSearch*/);
            hasError = (r.location != NSNotFound);
        }

        if(message) {
            NSRange r2 = ((NSRange(*)(id,SEL,id,NSUInteger))objc_msgSend)(message, selRange, ns_encrypt("technical"), 1);
            hasTechnical = (r2.location != NSNotFound);
        }

        if(hasError && hasTechnical) {
            return;
        }
    }

    %orig(viewController, flag, completion);
}
%end

