static NSString *random_uuid() {
    return [[NSUUID UUID] UUIDString];
}

uint32_t my__dyld_image_count(void) {
    return static_cast<uint32_t>(dyld_summary.size());
}

const char* my__dyld_get_image_name(uint32_t index) {
    if (index >= dyld_summary.size()) {
        return nullptr;
    }
    
    return dyld_summary[index].name.get();
}

const struct mach_header* my__dyld_get_image_header(uint32_t index) {
    if (index < 0 || index >= static_cast<int>(dyld_summary.size()))
        return nullptr;

    return dyld_summary[index].header;
}

intptr_t my__dyld_get_image_vmaddr_slide(uint32_t index) {
    if (index < 0 || index >= static_cast<int>(dyld_summary.size())) return 0;
    return dyld_summary[index].slide;
}

static int (*orig_dladdr)(const void *addr, Dl_info *info);
int hk_dladdr(const void *addr, Dl_info *info) {
    int ret = orig_dladdr(addr, info);
    if (ret && info && info->dli_fname && is_hidden_path(info->dli_fname)) {
        info->dli_fname = ay_obfuscate("/usr/lib/libobjc.A.dylib");
    }
    return ret;
}

static void *(*og_dlsym)(void *handle, const char *symbol);
static void *hk_dlsym(void *handle, const char *symbol) {
    // log_async(symbol);
    if (strcmp(symbol, ay_obfuscate("_dyld_image_count")) == 0) {
        return (void*)&my__dyld_image_count;
    }
    if (strcmp(symbol, ay_obfuscate("_dyld_get_image_name")) == 0) {
        return (void*)&my__dyld_get_image_name;
    }
    if (strcmp(symbol, ay_obfuscate("_dyld_get_image_header")) == 0) {
        return (void*)&my__dyld_get_image_header;
    }
    if (strcmp(symbol, ay_obfuscate("_dyld_get_image_vmaddr_slide")) == 0) {
        return (void*)&my__dyld_get_image_vmaddr_slide;
    }
    if (strcmp(symbol, ay_obfuscate("task_info")) == 0) {
        return (void*)&hk_task_info;
    }
    if (strcmp(symbol, "dladdr") == 0) return (void*)&hk_dladdr;

    return og_dlsym(handle, symbol);
}

// UIDevice.identifierForVendor
%hook UIDevice
- (NSString *)model {
    return ns_encrypt("SM-J500H");
}

- (NSString *)systemName {
    return ns_encrypt("Android");
}

- (NSString *)systemVersion {
    return ns_encrypt("7.0");
}

- (NSString *)name {
    return ns_encrypt("SAMSUNG");
}

- (NSString *)localizedModel {
    return ns_encrypt("SAMSUNG");
}

- (NSUUID *)identifierForVendor {
    static NSUUID *fake = nil;
    if (!fake) {
        NSString *docs = [NSSearchPathForDirectoriesInDomains(NSDocumentDirectory, NSUserDomainMask, YES) firstObject];
        NSString *filePath = [docs stringByAppendingPathComponent:ns_encrypt("spoof.txt")];
        
        NSFileManager *fm = [NSFileManager defaultManager];
        if ([fm fileExistsAtPath:filePath]) {
            NSString *uuidString = [NSString stringWithContentsOfFile:filePath encoding:NSUTF8StringEncoding error:nil];
            if (uuidString.length > 0) {
                fake = [[NSUUID alloc] initWithUUIDString:uuidString];
            }
        }
        
        if (!fake) {
            fake = [[NSUUID alloc] initWithUUIDString:random_uuid()];
            [fake.UUIDString writeToFile:filePath atomically:YES encoding:NSUTF8StringEncoding error:nil];
        }
    }
    return fake;
}
%end

static int (*orig_sysctlbyname)(const char *name, void *oldp, size_t *oldlenp,
                                void *newp, size_t newlen);

static NSString *spoofedMachine = nil;

static NSString *getSpoofedMachine() {
    if (spoofedMachine) return spoofedMachine;
    
    NSString *docs = [NSSearchPathForDirectoriesInDomains(NSDocumentDirectory, NSUserDomainMask, YES) firstObject];
    NSString *filePath = [docs stringByAppendingPathComponent:ns_encrypt("model.txt")];

    NSMutableDictionary *dict = [NSMutableDictionary dictionaryWithContentsOfFile:filePath];
    if (!dict) dict = [NSMutableDictionary dictionary];

    NSString *saved = dict[ns_encrypt("hw.machine")];
    if (saved && saved.length > 0) {
        spoofedMachine = saved;
    } else {
        int major = arc4random_uniform(10) + 1;
        int minor = arc4random_uniform(10);
        spoofedMachine = [NSString stringWithFormat:@"iPhone%d,%d", major, minor];
        //spoofedMachine = ns_encrypt("samsung5,0");
        dict[ns_encrypt("hw.machine")] = spoofedMachine;
        [dict writeToFile:filePath atomically:YES];
    }
    return spoofedMachine;
}

int hk_sysctlbyname(const char *name, void *oldp, size_t *oldlenp,
                    void *newp, size_t newlen) {
    if (strcmp(name, ay_obfuscate("hw.machine")) == 0 && oldp && oldlenp) {
        NSString *val = getSpoofedMachine();
        const char *spoof = [val UTF8String];
        size_t len = strlen(spoof);

        if (*oldlenp >= len + 1) {
            strcpy((char *)oldp, spoof);
            *oldlenp = len;
            return 0;
        }
    }
    return orig_sysctlbyname(name, oldp, oldlenp, newp, newlen);
}

static int (*orig_uname)(struct utsname *buf);
int hk_uname(struct utsname *buf) {
    int ret = orig_uname(buf);
    if (ret == 0 && buf) {
        int major = arc4random_uniform(10) + 1;
        int minor = arc4random_uniform(10);

        std::string machine = crypt_string("iPhone") + std::to_string(major) + crypt_string(",") + std::to_string(minor);

        strcpy(buf->machine, machine.c_str());
    }
    return ret;
}

__attribute__((constructor))
static void init_dyld_hooks() {
   dispatch_after(dispatch_time(DISPATCH_TIME_NOW, 1 * NSEC_PER_SEC), dispatch_get_main_queue(), ^{
        utsname systemInfo;
        uname( &systemInfo );
        g_ctx->backup_model = systemInfo.machine;
        NSUUID* identifierForVendor = [[UIDevice currentDevice] identifierForVendor];
        g_ctx->backup_hardware = [[identifierForVendor UUIDString] UTF8String];
        aggregate_dyld();
        %init(dyld_hooks);
        %init(_ungrouped);
        struct rebinding rebs[] = {
            { ("dlsym"), (void *)hk_dlsym, (void **)&og_dlsym },
            { ("task_info"), (void*)hk_task_info, (void**)&og_task_info },
            { ("sysctlbyname"), (void *)hk_sysctlbyname, (void **)&orig_sysctlbyname },
            { ("uname"), (void *)hk_uname, (void **)&orig_uname },
            //{ "exit", (void*)hk_exit, (void**)&orig_exit },
            //{ "abort", (void*)hk_abort, (void**)&orig_abort },
            //{ "_dyld_image_count", (void*)my__dyld_image_count, (void**)&orig__dyld_image_count },
            //{ "_dyld_get_image_name", (void*)my__dyld_get_image_name, (void**)&orig__dyld_get_image_name },
            //{ "_dyld_get_image_header", (void*)my__dyld_get_image_header, (void**)&orig__dyld_get_image_header },
            //{ "_dyld_get_image_vmaddr_slide", (void*)my__dyld_get_image_vmaddr_slide, (void**)&orig__dyld_get_image_vmaddr_slide }
        };
        rebind_symbols(rebs, sizeof(rebs) / sizeof(rebs[0]));
    });
}
